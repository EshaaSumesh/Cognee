# ---- LLM (required) ----
# Cognee extracts knowledge with an LLM. OpenAI by default.
LLM_API_KEY="sk-..."
LLM_PROVIDER="openai"
LLM_MODEL="gpt-4o-mini"
EMBEDDING_MODEL="text-embedding-3-small"

# ---- Cognee memory layer: self-hosted, open-source, 100% local ----
# The whole memory layer (graph + vector + metadata) runs on Postgres.
DB_PROVIDER="postgres"
VECTOR_DB_PROVIDER="pgvector"
GRAPH_DATABASE_PROVIDER="kuzu"
CACHE_BACKEND="postgres"

DB_HOST="postgres"
DB_PORT="5432"
DB_USERNAME="cognee"
DB_PASSWORD="cognee"
DB_NAME="cognee_db"

# Where Cognee keeps its embedded data (graph/vector files) inside the backend container
COGNEE_DATA_ROOT="/data/cognee"
COGNEE_SYSTEM_ROOT="/data/cognee_system"

# ---- Optional: Neo4j graph backend (better demo visuals) ----
# Enable with: docker compose --profile neo4j up
# GRAPH_DATABASE_PROVIDER="neo4j"
GRAPH_DATABASE_URL="bolt://neo4j:7687"
GRAPH_DATABASE_USERNAME="neo4j"
GRAPH_DATABASE_PASSWORD="cognee_graph"

# ---- Optional: Cognee Cloud fallback (NOT used for the OSS track) ----
# COGNEE_BASE_URL="https://your-instance.cognee.ai"
# COGNEE_API_KEY="ck_..."

# ---- App ----
BACKEND_PORT="8000"
AUDIT_SIGNING_SECRET="change-me-in-prod"
